{
  "name": "mcp-confluence-server",
  "version": "1.0.0",
  "description": "MCP server for Confluence Cloud REST API v2",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start:stdio": "node dist/index.js",
    "start:http": "node dist/server-http.js",
    "dev": "tsc -w",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["mcp", "confluence", "atlassian"],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0",
    "eslint": "^8.55.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0"
  }
}
